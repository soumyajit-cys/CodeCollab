{
  "name": "codecollab",
  "version": "1.0.0",
  "description": "Real-time collaborative code editor with AI assistant",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently &quot;npm run server&quot; &quot;npm run client&quot;",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "mongoose": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "nodemailer": "^6.9.4",
    "twilio": "^4.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "openai": "^4.5.0",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1"
  }
}